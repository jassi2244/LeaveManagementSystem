@model LeaveManagementSystem.ViewModels.DashboardAdminVM
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-tachometer-alt mr-2 text-primary"></i>
                    Dashboard
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>
@if (ViewBag.DashboardLoadError != null)
{
    <div class="alert alert-danger">@ViewBag.DashboardLoadError</div>
}
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-gradient-info">
            <div class="inner">
                <h3>@Model.TotalEmployees</h3>
                <p>Total Employees</p>
            </div>
            <div class="icon">
                <i class="fas fa-users"></i>
            </div>
            <a asp-controller="Admin" asp-action="Employees" class="small-box-footer">
                View All <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-gradient-warning">
            <div class="inner">
                <h3>@Model.TotalPendingRequests</h3>
                <p>Pending Requests</p>
            </div>
            <div class="icon">
                <i class="fas fa-clock"></i>
            </div>
            <a asp-controller="LeaveRequest" asp-action="Index" class="small-box-footer">
                View All <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-gradient-success">
            <div class="inner">
                <h3>@Model.TotalApprovedThisMonth</h3>
                <p>Approved This Month</p>
            </div>
            <div class="icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <a asp-controller="LeaveRequest" asp-action="Index" class="small-box-footer">
                View All <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="small-box bg-gradient-danger">
            <div class="inner">
                <h3>@Model.TotalRejectedThisMonth</h3>
                <p>Rejected This Month</p>
            </div>
            <div class="icon">
                <i class="fas fa-times-circle"></i>
            </div>
            <a asp-controller="LeaveRequest" asp-action="Index" class="small-box-footer">
                View All <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
</div>
<div class="row mt-3">
    <div class="col-md-5">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-pie mr-2"></i>
                    Leave Status Overview
                </h3>
            </div>
            <div class="card-body">
                <div class="dashboard-chart-wrap">
                    <canvas id="leaveStatusPie" style="max-height:280px;"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card card-outline card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-bar mr-2"></i>
                    Monthly Leave Requests
                </h3>
            </div>
            <div class="card-body">
                <div class="dashboard-chart-wrap">
                    <canvas id="monthlyLeaveBar" style="max-height:280px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-warning mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-clock mr-2"></i>
            Recent Pending Requests
        </h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Leave Type</th>
                    <th>Dates</th>
                    <th>Days</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.RecentPendingRequests)
            {
                <tr>
                    <td>@item.EmployeeName</td>
                    <td>@item.LeaveTypeName</td>
                    <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                    <td>@item.NumberOfDays</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script src="~/js/dashboard.js"></script> }
