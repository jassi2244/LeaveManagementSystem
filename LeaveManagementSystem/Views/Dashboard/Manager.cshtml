@model LeaveManagementSystem.ViewModels.DashboardManagerVM
@{
    ViewData["Title"] = "Manager Dashboard";
    Layout = "_ManagerLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-tachometer-alt mr-2 text-primary"></i>
                    Dashboard
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Dashboard</li>
                </ol>
            </div>
        </div>
    </div>
</div>
@if (ViewBag.DashboardLoadError != null)
{
    <div class="alert alert-danger">@ViewBag.DashboardLoadError</div>
}
<div class="row">
    <div class="col-md-4">
        <div class="info-box bg-gradient-teal">
            <span class="info-box-icon"><i class="fas fa-users"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Team Size</span>
                <span class="info-box-number">@Model.TeamSize</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box bg-gradient-warning">
            <span class="info-box-icon"><i class="fas fa-hourglass-half"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Pending Approvals</span>
                <span class="info-box-number">@Model.PendingApprovals</span>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="info-box bg-gradient-success">
            <span class="info-box-icon"><i class="fas fa-check-double"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Approved This Month</span>
                <span class="info-box-number">@Model.ApprovedThisMonth</span>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-warning">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-clock mr-2"></i>Team Pending Requests
        </h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Employee</th><th>Leave Type</th><th>Dates</th><th>Action</th></tr></thead>
            <tbody>
            @foreach (var item in Model.TeamPendingRequests)
            {
                <tr>
                    <td>@item.EmployeeName</td>
                    <td>@item.LeaveTypeName</td>
                    <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                    <td>
                        <a class="btn btn-success btn-sm" asp-controller="LeaveRequest" asp-action="Approve" asp-route-id="@item.Id"><i class="fas fa-check mr-1"></i>Approve</a>
                        <button class="btn btn-danger btn-sm reject-btn" data-id="@item.Id"><i class="fas fa-times mr-1"></i>Reject</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
