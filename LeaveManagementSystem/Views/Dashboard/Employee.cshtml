@model LeaveManagementSystem.ViewModels.DashboardEmployeeVM
@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "_EmployeeLayout";
}
@{
    var colors = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "Annual Leave", "linear-gradient(135deg,#11998e,#38ef7d)" },
        { "Casual Leave", "linear-gradient(135deg,#f093fb,#f5576c)" },
        { "Sick Leave", "linear-gradient(135deg,#4facfe,#00f2fe)" },
        { "Maternity Leave", "linear-gradient(135deg,#fa709a,#fee140)" },
        { "Paternity Leave", "linear-gradient(135deg,#a18cd1,#fbc2eb)" }
    };
    var icons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "Annual Leave", "fa-umbrella-beach" },
        { "Casual Leave", "fa-coffee" },
        { "Sick Leave", "fa-procedures" },
        { "Maternity Leave", "fa-baby" },
        { "Paternity Leave", "fa-male" }
    };
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-tachometer-alt mr-2 text-primary"></i>
                    My Dashboard
                </h1>
            </div>
            <div class="col-sm-6 text-right">
                <a asp-controller="LeaveRequest" asp-action="Apply" class="btn btn-primary">
                    <i class="fas fa-paper-plane mr-1"></i>
                    Apply for Leave
                </a>
            </div>
        </div>
    </div>
</div>
@if (ViewBag.DashboardLoadError != null)
{
    <div class="alert alert-danger">@ViewBag.DashboardLoadError</div>
}
<div class="row">
    @foreach (var item in Model.LeaveBalances)
    {
        var gradient = colors.ContainsKey(item.LeaveTypeName) ? colors[item.LeaveTypeName] : "linear-gradient(135deg,#667eea,#764ba2)";
        var icon = icons.ContainsKey(item.LeaveTypeName) ? icons[item.LeaveTypeName] : "fa-calendar";
        <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
            <div class="card border-0 text-white" style="background:@gradient; border-radius:12px; box-shadow:0 4px 15px rgba(0,0,0,0.15);">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title text-white mb-0 font-weight-bold">@item.LeaveTypeName</h6>
                        <i class="fas @icon" style="font-size:1.8rem; opacity:0.7;"></i>
                    </div>

                    <div class="row text-center mt-3">
                        <div class="col-4">
                            <div style="font-size:1.5rem; font-weight:bold;">@item.TotalDays</div>
                            <small style="opacity:0.85;">Total</small>
                        </div>
                        <div class="col-4">
                            <div style="font-size:1.5rem; font-weight:bold;">@item.UsedDays</div>
                            <small style="opacity:0.85;">Used</small>
                        </div>
                        <div class="col-4">
                            <div style="font-size:1.5rem; font-weight:bold;">@item.RemainingDays</div>
                            <small style="opacity:0.85;">Left</small>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="progress" style="height:4px; background:rgba(255,255,255,0.3);">
                            <div class="progress-bar bg-white" style="width:@(item.TotalDays > 0 ? (item.UsedDays * 100 / item.TotalDays) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<div class="card card-outline card-primary mt-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-history mr-2"></i>
            Recent Leave Requests
        </h3>
        <div class="card-tools">
            <a asp-controller="LeaveRequest" asp-action="MyRequests" class="btn btn-tool btn-sm">
                View All <i class="fas fa-arrow-right ml-1"></i>
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Leave Type</th><th>Dates</th><th>Status</th></tr></thead>
            <tbody>
            @foreach (var item in Model.RecentRequests)
            {
                <tr>
                    <td>@item.LeaveTypeName</td>
                    <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                    <td>
                        @if (item.Status == "Approved")
                        {
                            <span class="badge badge-success"><i class="fas fa-check mr-1"></i>Approved</span>
                        }
                        else if (item.Status == "Pending")
                        {
                            <span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pending</span>
                        }
                        else if (item.Status == "Rejected")
                        {
                            <span class="badge badge-danger"><i class="fas fa-times mr-1"></i>Rejected</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">@item.Status</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
