@model LeaveManagementSystem.ViewModels.ReportFilterVM
@{
    ViewData["Title"] = "Leave Report";
    Layout = "_Layout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-chart-bar mr-2 text-primary"></i>
                    Leave Report
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Leave Report</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<form asp-action="LeaveReport" method="get">
    <div class="card card-outline card-secondary mb-3">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-filter mr-2"></i>Filter Reports
            </h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-2">
                    <label>Department</label>
                    <select class="form-control form-control-sm" name="DepartmentId">
                        <option value="">All Departments</option>
                        @if (Model.DepartmentId.HasValue)
                        {
                            <option value="@Model.DepartmentId" selected>Department #@Model.DepartmentId</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Leave Type</label>
                    <select class="form-control form-control-sm" name="LeaveTypeId">
                        <option value="">All Types</option>
                        @if (Model.LeaveTypeId.HasValue)
                        {
                            <option value="@Model.LeaveTypeId" selected>Leave Type #@Model.LeaveTypeId</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Status</label>
                    <select class="form-control form-control-sm" name="Status">
                        <option value="">All Status</option>
                        @if (Model.Status == "Pending")
                        {
                            <option value="Pending" selected>Pending</option>
                        }
                        else
                        {
                            <option value="Pending">Pending</option>
                        }
                        @if (Model.Status == "Approved")
                        {
                            <option value="Approved" selected>Approved</option>
                        }
                        else
                        {
                            <option value="Approved">Approved</option>
                        }
                        @if (Model.Status == "Rejected")
                        {
                            <option value="Rejected" selected>Rejected</option>
                        }
                        else
                        {
                            <option value="Rejected">Rejected</option>
                        }
                        @if (Model.Status == "Cancelled")
                        {
                            <option value="Cancelled" selected>Cancelled</option>
                        }
                        else
                        {
                            <option value="Cancelled">Cancelled</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Employee</label>
                    <input asp-for="EmployeeName" class="form-control form-control-sm" placeholder="Name contains..." />
                </div>
                <div class="col-md-2">
                    <label>From Date</label>
                    <input asp-for="FromDate" type="date" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label>To Date</label>
                    <input asp-for="ToDate" type="date" class="form-control form-control-sm" />
                </div>
                <div class="col-12 mt-3">
                    <div class="d-flex align-items-center flex-wrap">
                        <button class="btn btn-primary btn-sm mr-2 mb-1" type="submit">
                            <i class="fas fa-search mr-1"></i>Filter
                        </button>
                        <a asp-action="LeaveReport" class="btn btn-default btn-sm mb-1">
                            <i class="fas fa-redo mr-1"></i>Reset
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
<form asp-action="ExportToExcel" method="post" class="mb-3 d-flex justify-content-end">
    <input type="hidden" asp-for="DepartmentId" />
    <input type="hidden" asp-for="LeaveTypeId" />
    <input type="hidden" asp-for="Status" />
    <input type="hidden" asp-for="EmployeeName" />
    <input type="hidden" asp-for="FromDate" />
    <input type="hidden" asp-for="ToDate" />
    <input type="hidden" asp-for="Year" />
    <button class="btn btn-success btn-sm" type="submit">
        <i class="fas fa-file-excel mr-1"></i>Export
    </button>
</form>
<form asp-action="ExportToPdf" method="post" class="mb-3 d-flex justify-content-end">
    <input type="hidden" asp-for="DepartmentId" />
    <input type="hidden" asp-for="LeaveTypeId" />
    <input type="hidden" asp-for="Status" />
    <input type="hidden" asp-for="EmployeeName" />
    <input type="hidden" asp-for="FromDate" />
    <input type="hidden" asp-for="ToDate" />
    <input type="hidden" asp-for="Year" />
    <button class="btn btn-danger btn-sm" type="submit">
        <i class="fas fa-file-pdf mr-1"></i>Export PDF
    </button>
</form>
<div class="card card-outline card-info mb-3">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-chart-pie mr-2"></i>Report Summary
        </h3>
    </div>
    <div class="card-body">
        <div class="report-summary-chart-wrap">
            <canvas id="reportSummaryChart"></canvas>
        </div>
    </div>
</div>
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-table mr-2"></i>Report Results
        </h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Employee</th><th>Type</th><th>Dates</th><th>Days</th><th>Status</th></tr></thead>
            <tbody>
            @foreach (var r in Model.Records)
            {
                <tr>
                    <td>@r.EmployeeName</td>
                    <td>@r.LeaveTypeName</td>
                    <td>@r.StartDate.ToShortDateString() - @r.EndDate.ToShortDateString()</td>
                    <td>@r.NumberOfDays</td>
                    <td>
                        @if (r.Status == "Approved")
                        {
                            <span class="badge badge-success"><i class="fas fa-check mr-1"></i>Approved</span>
                        }
                        else if (r.Status == "Pending")
                        {
                            <span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pending</span>
                        }
                        else if (r.Status == "Rejected")
                        {
                            <span class="badge badge-danger"><i class="fas fa-times mr-1"></i>Rejected</span>
                        }
                        else if (r.Status == "Cancelled")
                        {
                            <span class="badge badge-secondary"><i class="fas fa-ban mr-1"></i>Cancelled</span>
                        }
                        else
                        {
                            <span class="badge badge-light">@r.Status</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@section Scripts { <script src="~/js/report.js"></script> }
