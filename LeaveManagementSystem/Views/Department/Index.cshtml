@model IEnumerable<LeaveManagementSystem.ViewModels.DepartmentVM>
@{
    ViewData["Title"] = "Departments";
    Layout = "_AdminLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-building mr-2 text-primary"></i>
                    Departments
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Departments</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-building mr-2"></i>Department Master
        </h3>
        <div class="card-tools">
            <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus mr-1"></i>Add Department</a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Name</th><th>Description</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                var colors = new[] { "#6f42c1", "#17a2b8", "#20c997", "#fd7e14", "#6610f2" };
                var color = colors[Math.Abs(item.Name.GetHashCode()) % colors.Length];
                <tr>
                    <td>
                        <span class="icon-chip mr-2" style="background-color:@color;">
                            <i class="fas fa-building"></i>
                        </span>
                        @item.Name
                    </td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning" aria-label="Edit @item.Name"><i class="fas fa-edit"></i></a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline swal-confirm-form" data-title="Delete department?" data-text="This department will be removed.">
                            <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Delete @item.Name"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
