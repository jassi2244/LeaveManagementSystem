@model IEnumerable<LeaveManagementSystem.Models.LeaveRequest>
@{
    ViewData["Title"] = "Leave Requests";
    Layout = "_Layout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-calendar-alt mr-2 text-primary"></i>
                    Leave Requests
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Leave Requests</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-calendar-alt mr-2"></i>Requests
        </h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead>
                <tr><th>Employee</th><th>Leave Type</th><th>Dates</th><th>Days</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.RequestingEmployee?.FullName</td>
                    <td>@item.LeaveType?.Name</td>
                    <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                    <td>@item.NumberOfDays</td>
                    <td>
                        @if (item.Status == "Approved")
                        {
                            <span class="badge badge-success"><i class="fas fa-check mr-1"></i>Approved</span>
                        }
                        else if (item.Status == "Pending")
                        {
                            <span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pending</span>
                        }
                        else if (item.Status == "Rejected")
                        {
                            <span class="badge badge-danger"><i class="fas fa-times mr-1"></i>Rejected</span>
                        }
                        else if (item.Status == "Cancelled")
                        {
                            <span class="badge badge-secondary"><i class="fas fa-ban mr-1"></i>Cancelled</span>
                        }
                        else
                        {
                            <span class="badge badge-light">@item.Status</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id"><i class="fas fa-eye mr-1"></i>View</a>
                        @if ((User.IsInRole("Admin") || User.IsInRole("Manager")) && item.Status == "Pending")
                        {
                            <a class="btn btn-success btn-sm" asp-action="Approve" asp-route-id="@item.Id"><i class="fas fa-check mr-1"></i>Approve</a>
                            <button class="btn btn-danger btn-sm reject-btn" data-id="@item.Id"><i class="fas fa-times mr-1"></i>Reject</button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
