@model IEnumerable<LeaveManagementSystem.Models.LeaveRequest>
@{
    ViewData["Title"] = "My Requests";
    Layout = "_EmployeeLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-calendar-alt mr-2 text-primary"></i>
                    My Leave Requests
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index"><i class="fas fa-home"></i> Home</a>
                    </li>
                    <li class="breadcrumb-item active">My Leave Requests</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-calendar-alt mr-2"></i>
            My Leave Requests
        </h3>
        <div class="card-tools">
            <a asp-controller="LeaveRequest" asp-action="Apply" class="btn btn-primary btn-sm">
                <i class="fas fa-plus mr-1"></i>Apply Leave
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Type</th><th>Dates</th><th>Days</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <span class="badge badge-pill leave-type-dot"></span>
                        @item.LeaveType?.Name
                    </td>
                    <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                    <td>@item.NumberOfDays</td>
                    <td>
                        @if (item.Status == "Approved")
                        {
                            <span class="badge badge-success"><i class="fas fa-check mr-1"></i>Approved</span>
                        }
                        else if (item.Status == "Pending")
                        {
                            <span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pending</span>
                        }
                        else if (item.Status == "Rejected")
                        {
                            <span class="badge badge-danger"><i class="fas fa-times mr-1"></i>Rejected</span>
                        }
                        else if (item.Status == "Cancelled")
                        {
                            <span class="badge badge-secondary"><i class="fas fa-ban mr-1"></i>Cancelled</span>
                        }
                        else
                        {
                            <span class="badge badge-light">@item.Status</span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            <button class="btn btn-warning btn-sm cancel-btn" data-id="@item.Id">
                                <i class="fas fa-ban mr-1"></i>Cancel
                            </button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
