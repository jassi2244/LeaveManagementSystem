@model LeaveManagementSystem.ViewModels.LeaveAllocationVM
@{
    ViewData["Title"] = "Leave Allocations";
    Layout = "_AdminLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-layer-group mr-2 text-primary"></i>
                    Leave Allocations
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index"><i class="fas fa-home"></i> Home</a>
                    </li>
                    <li class="breadcrumb-item active">Leave Allocations</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card card-outline card-primary">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-plus-circle mr-2"></i>Allocate Leave
                        </h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="Allocations" method="post" id="allocationForm">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="UserId">
                                            <i class="fas fa-user mr-1 text-muted"></i>Employee Id
                                        </label>
                                        <input asp-for="UserId" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="LeaveTypeId">
                                            <i class="fas fa-list-alt mr-1 text-muted"></i>Leave Type Id
                                        </label>
                                        <input asp-for="LeaveTypeId" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="NumberOfDays">
                                            <i class="fas fa-calendar-day mr-1 text-muted"></i>Number Of Days
                                        </label>
                                        <input asp-for="NumberOfDays" class="form-control" />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label asp-for="Year">
                                            <i class="fas fa-clock mr-1 text-muted"></i>Year
                                        </label>
                                        <input asp-for="Year" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="card-footer bg-light">
                        <button class="btn btn-primary mr-2" type="submit" form="allocationForm">
                            <i class="fas fa-save mr-1"></i>Save Allocation
                        </button>
                        <button class="btn btn-outline-secondary" type="reset" form="allocationForm">
                            <i class="fas fa-redo mr-1"></i>Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
