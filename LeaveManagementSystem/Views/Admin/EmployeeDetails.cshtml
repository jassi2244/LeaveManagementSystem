@model LeaveManagementSystem.Models.ApplicationUser
@{
    ViewData["Title"] = "Employee Details";
    Layout = "_AdminLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-id-card mr-2 text-primary"></i>
                    Employee Details
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Admin" asp-action="Employees">Employees</a>
                    </li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="content">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card card-outline card-primary">
                    <div class="card-header profile-header-accent">
                        <div class="d-flex align-items-center">
                            <div class="avatar-circle-lg">
                                @(Model.FullName?.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "?")
                            </div>
                            <div>
                                <h4 class="mb-0 text-white font-weight-bold">@Model.FullName</h4>
                                <small style="color:rgba(255,255,255,0.8);">@Model.Email</small>
                            </div>
                        </div>
                    </div>

                    <div class="card-body pt-4">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="info-icon-box" style="background:#ede9fe;">
                                        <i class="fas fa-envelope text-primary"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block font-weight-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Email Address</small>
                                        <span class="font-weight-500">@Model.Email</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-4">
                                    <div class="info-icon-box" style="background:#dcfce7;">
                                        <i class="fas fa-building text-success"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block font-weight-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Department</small>
                                        <span>@((Model.Department != null && Model.Department.IsActive) ? Model.Department.Name : "Not Assigned")</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-4">
                                    <div class="info-icon-box" style="background:#fef9c3;">
                                        <i class="fas fa-user-tie text-warning"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block font-weight-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Reporting Manager</small>
                                        <span>@(string.IsNullOrEmpty(Model.Manager?.FullName) ? "Not Assigned" : Model.Manager.FullName)</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="info-icon-box" style="background:#dbeafe;">
                                        <i class="fas fa-calendar-day text-info"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block font-weight-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Date of Joining</small>
                                        <span>@(Model.DateOfJoining.HasValue ? Model.DateOfJoining.Value.ToString("dd MMM yyyy") : "Not Set")</span>
                                    </div>
                                </div>

                                <div class="d-flex align-items-center mb-4">
                                    <div class="info-icon-box" style="background:#f0fdf4;">
                                        <i class="fas fa-toggle-on text-success"></i>
                                    </div>
                                    <div>
                                        <small class="text-muted d-block font-weight-bold" style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">Status</small>
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge badge-success px-3 py-1">
                                                <i class="fas fa-check mr-1"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger px-3 py-1">
                                                <i class="fas fa-times mr-1"></i>Inactive
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-light">
                        <a asp-controller="Admin" asp-action="Employees" class="btn btn-default btn-sm mr-2">
                            <i class="fas fa-arrow-left mr-1"></i>
                            Back to Employees
                        </a>
                        <a href="/Admin/EditEmployee/@Model.Id" class="btn btn-warning btn-sm">
                            <i class="fas fa-edit mr-1"></i>
                            Edit Employee
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
