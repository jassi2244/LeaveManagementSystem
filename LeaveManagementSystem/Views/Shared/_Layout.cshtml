@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LeaveManagementSystem</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.8/css/dataTables.bootstrap4.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <meta name="request-verification-token" content="@Antiforgery.GetAndStoreTokens(Context).RequestToken" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <a href="#main-content" class="sr-only sr-only-focusable">Skip to main content</a>
    <div id="globalLoader" role="status" aria-live="polite" aria-label="Loading"></div>
    <div id="uiAnnouncements" class="sr-only" aria-live="polite" aria-atomic="true"></div>
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand navbar-white navbar-light border-bottom">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar" aria-controls="app-sidebar" aria-expanded="true">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link" data-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false" aria-label="Open user menu">
                            <div class="nav-user-avatar">
                                @(User.Identity.Name?.Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "U")
                            </div>
                            <span class="d-none d-md-inline">@User.Identity.Name</span>
                            <i class="fas fa-chevron-down ml-1" style="font-size:11px;"></i>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right dropdown-menu-lg shadow">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt mr-2"></i>
                                    Sign Out
                                </button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        </nav>
        @await Html.PartialAsync("_Sidebar")

        <div class="content-wrapper">
            <main id="main-content" tabindex="-1">
            <section class="content">
                <div class="container-fluid pb-3">
                    @RenderBody()
                </div>
            </section>
            </main>
        </div>

        <footer class="main-footer">
            <strong>Copyright &copy; @DateTime.Now.Year LeaveManagementSystem.</strong>
            All rights reserved.
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.8/js/dataTables.bootstrap4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (TempData["Success"] is string successMessage)
    {
        <script>
            toastr.success(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(successMessage)));
        </script>
    }
    @if (TempData["Error"] is string errorMessage)
    {
        <script>
            toastr.error(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(errorMessage)));
        </script>
    }
    @if (TempData["Info"] is string infoMessage)
    {
        <script>
            toastr.info(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(infoMessage)));
        </script>
    }
    @if (TempData["Warning"] is string warningMessage)
    {
        <script>
            toastr.warning(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(warningMessage)));
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
