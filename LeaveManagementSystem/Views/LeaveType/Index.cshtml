@model IEnumerable<LeaveManagementSystem.ViewModels.LeaveTypeVM>
@{
    ViewData["Title"] = "Leave Types";
    Layout = "_AdminLayout";
}
<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">
                    <i class="fas fa-list-alt mr-2 text-primary"></i>
                    Leave Types
                </h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-home"></i> Home
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Leave Types</li>
                </ol>
            </div>
        </div>
    </div>
</div>
<div class="card card-outline card-primary">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-list-alt mr-2"></i>Leave Type Master
        </h3>
        <div class="card-tools">
            <a class="btn btn-primary btn-sm" asp-action="Create">
                <i class="fas fa-plus mr-1"></i>Add Leave Type
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-bordered data-table mb-0">
            <thead><tr><th>Name</th><th>Default Days</th><th>Actions</th></tr></thead>
            <tbody>
            @foreach (var item in Model)
            {
                var icon = "fa-calendar-day";
                var color = "#6c757d";
                if (item.Name.Contains("Annual", StringComparison.OrdinalIgnoreCase)) { icon = "fa-umbrella-beach"; color = "#007bff"; }
                else if (item.Name.Contains("Sick", StringComparison.OrdinalIgnoreCase)) { icon = "fa-procedures"; color = "#dc3545"; }
                else if (item.Name.Contains("Casual", StringComparison.OrdinalIgnoreCase)) { icon = "fa-coffee"; color = "#fd7e14"; }
                else if (item.Name.Contains("Maternity", StringComparison.OrdinalIgnoreCase)) { icon = "fa-baby"; color = "#e83e8c"; }
                else if (item.Name.Contains("Paternity", StringComparison.OrdinalIgnoreCase)) { icon = "fa-male"; color = "#20c997"; }
                <tr>
                    <td>
                        <span class="icon-chip mr-2" style="background-color:@color;">
                            <i class="fas @icon"></i>
                        </span>
                        @item.Name
                    </td>
                    <td>@item.DefaultDays</td>
                    <td>
                        <a class="btn btn-sm btn-outline-warning" asp-action="Edit" asp-route-id="@item.Id" title="Edit" aria-label="Edit @item.Name"><i class="fas fa-edit"></i></a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline swal-confirm-form" data-title="Delete leave type?" data-text="This leave type will be removed.">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" aria-label="Delete @item.Name"><i class="fas fa-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
